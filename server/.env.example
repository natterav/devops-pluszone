# Supabase (PostgreSQL) - Conexión directa
# Obtén la URI en: Supabase → Project Settings → Database → Connection string → Direct connection
# Formato: postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Supabase Auth (verificación de correo sin SMTP; Supabase envía el email)
# Project Settings → API: Project URL = SUPABASE_URL, anon public = SUPABASE_ANON_KEY
# JWT Secret: Project Settings → API → JWT Secret (para validar tokens en /api/auth/session)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# Email (SMTP) - solo si usas flujo legacy de código 7 dígitos (opcional)
EMAIL_HOST=pro.eu.turbo-smtp.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_pass
EMAIL_FROM=PlusZone@tu-dominio.com
EMAIL_FALLBACK=true

# Puerto del servidor
PORT=4000

# Código de verificación (7 dígitos, flujo legacy): duración en minutos
VERIFICATION_EXPIRATION_MINUTES=15
